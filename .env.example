# ForesightFlow environment variables
# Copy to .env and fill in real values

# Database (default works with docker-compose)
FFLOW_DB_URL=postgresql+asyncpg://fflow:fflow@localhost:5432/fflow

# Polymarket APIs (no auth required)
FFLOW_GAMMA_API_URL=https://gamma-api.polymarket.com
FFLOW_CLOB_API_URL=https://clob.polymarket.com

# The Graph / Polymarket subgraph
FFLOW_SUBGRAPH_URL=https://gateway.thegraph.com/api/subgraphs/id/81Dm16JjuFSrqz813HysXoUPvzTwE7fsfPk2RTf66nyC
FFLOW_THEGRAPH_API_KEY=

# Polygonscan (get free key at polygonscan.com/myapikey)
FFLOW_POLYGONSCAN_API_KEY=
FFLOW_POLYGONSCAN_URL=https://api.polygonscan.com/api

# UMA Optimistic Oracle via Polygon JSON-RPC (public default works)
FFLOW_POLYGON_RPC_URL=https://polygon-rpc.com

# HTTP tuning
FFLOW_HTTP_TIMEOUT_SECONDS=30.0
FFLOW_HTTP_MAX_RETRIES=5
FFLOW_HTTP_BACKOFF_BASE_SECONDS=1.0

# Logging: set LOG_JSON=true in production
FFLOW_LOG_LEVEL=INFO
FFLOW_LOG_JSON=false
